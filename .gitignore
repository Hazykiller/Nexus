# See https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.zip

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env*.local

# vercel
.vercel

# typescript build artifacts (auto-generated)
*.tsbuildinfo
next-env.d.ts

# local-only scripts / seed files
tmp/
scripts/setup_db.js

# lint output
lint_output.txt
*.log

# AI agent temp files
AGENTS.md
CLAUDE.md
